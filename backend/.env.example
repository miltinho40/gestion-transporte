NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:4200
FRONTEND_URL=http://localhost:4200

DATABASE_URL="postgresql://postgres:tu_password@localhost:5432/transporte?schema=public"

JWT_SECRET="cambia-este-secreto-en-desarrollo"
JWT_EXPIRES_IN="8h"

# Opcional. Si no se configura SMTP_HOST, las invitaciones se generan pero no se envian por correo.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Gestion Transporte <no-reply@localhost>"
